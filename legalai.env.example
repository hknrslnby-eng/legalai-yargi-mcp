# LegalAI ürün anahtar şablonu (push edilebilir — boş değerler)
# Kopyalama: bu içeriği kökteki .env dosyasına birleştirin.
# Upstream .env.example (Clerk/OpenRouter) silinmesin.

# --- LegalAI LLM router ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# https://platform.claude.com/settings/keys
ANTHROPIC_API_KEY=
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# https://platform.deepseek.com
DEEPSEEK_API_KEY=
# https://console.groq.com/keys
GROQ_API_KEY=
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# --- Provider key template (all blank by design) ---
# The current local router actively uses only the providers documented in its
# settings. The remaining fields are reserved, inactive examples: entering a
# key does not activate a provider that the installed version does not support.
MISTRAL_API_KEY=
COHERE_API_KEY=
PERPLEXITY_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
CEREBRAS_API_KEY=
XAI_API_KEY=
KIMI_API_KEY=
MOONSHOT_API_KEY=
GLM_API_KEY=
ZHIPU_API_KEY=
QWEN_API_KEY=
DASHSCOPE_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AWS_BEDROCK_ACCESS_KEY_ID=
AWS_BEDROCK_SECRET_ACCESS_KEY=
GITHUB_COPILOT_TOKEN=
COMPOSER_API_KEY=
OLLAMA_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=

# --- Upstream opsiyonel ---
TAVILY_API_KEY=
BRAVE_API_TOKEN=

# --- Tenant / depolama ---
TENANT_ID=local
TENANT_NAME=Local
STORAGE_ROOT=./.data
DATABASE_URL=sqlite+aiosqlite:///./.data/legalai.db
CORPUS_DB_PATH=./.data/socratlegal_corpus.db
# Live official adapters are keyword-gated; set false to disable them.
SOCRATLEGAL_ENABLE_OFFICIAL_ADAPTERS=true
ENABLE_AGGRESSIVE_OPPOSING=true
ENABLE_DEEP_RESEARCH=true
ENABLE_AUTH=false
