# LegalAI ürün anahtar şablonu (push edilebilir — boş değerler)
# Kopyalama: bu içeriği kökteki .env dosyasına birleştirin.
# Upstream .env.example (Clerk/OpenRouter) silinmesin.

# --- LegalAI LLM router ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# https://platform.claude.com/settings/keys
ANTHROPIC_API_KEY=
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# https://platform.deepseek.com
DEEPSEEK_API_KEY=
# https://console.groq.com/keys
GROQ_API_KEY=
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# --- Upstream opsiyonel ---
TAVILY_API_KEY=
BRAVE_API_TOKEN=

# --- Tenant / depolama ---
TENANT_ID=local
TENANT_NAME=Local
STORAGE_ROOT=./.data
DATABASE_URL=sqlite+aiosqlite:///./.data/legalai.db
CORPUS_DB_PATH=./.data/socratlegal_corpus.db
# Live official adapters are keyword-gated; set false to disable them.
SOCRATLEGAL_ENABLE_OFFICIAL_ADAPTERS=true
ENABLE_AGGRESSIVE_OPPOSING=true
ENABLE_DEEP_RESEARCH=true
ENABLE_AUTH=false
